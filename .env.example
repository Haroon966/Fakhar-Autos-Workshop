# Hostinger SSH (hPanel → Advanced → SSH Access)
# Enable SSH, note hostname + username, add your public key (~/.ssh/id_ed25519.pub)
SSH_HOST=srv123.hostinger.com
SSH_USER=u123456789
SSH_PORT=65002
SSH_REMOTE_PATH=domains/fakharautoworkshop.com/public_html
SSH_KEY=~/.ssh/id_ed25519

# Optional FTP fallback (scripts/deploy-hostinger-ftp.mjs)
# FTP_HOST=ftp.fakharautoworkshop.com
# FTP_USER=u123456789
# FTP_PASSWORD=your-ftp-password
# FTP_REMOTE_DIR=public_html
