---
import { SITE } from '../data/site';
import { routeUrl, stripBasePath } from '../utils/paths';

interface Props {
	transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = stripBasePath(Astro.url.pathname);
const isActive = (path: string) =>
	currentPath === path || (path !== '/' && currentPath.startsWith(path));
---

<header class:list={['header', { 'header--transparent': transparent }]}>
	<div class="header__bar layout">
		<a href={routeUrl('/')} class="header__logo" aria-label={`${SITE.name} Home`}>
			{SITE.shortName}
		</a>
		<button
			type="button"
			class="header__menu-btn"
			aria-label="Open menu"
			aria-expanded="false"
			aria-controls="nav-menu"
			id="menu-toggle"
		>
			<span class="header__menu-icon" aria-hidden="true"></span>
		</button>
		<nav class="header__nav" id="nav-menu" aria-label="Main">
			<ul class="header__nav-list">
				<li><a href={routeUrl('/services/')} class:list={['header__link', { active: isActive('/services/') }]}>Services</a></li>
				<li><a href={routeUrl('/faq/')} class:list={['header__link', { active: isActive('/faq/') }]}>FAQ</a></li>
				<li><a href={routeUrl('/about/')} class:list={['header__link', { active: isActive('/about/') }]}>About</a></li>
				<li><a href={routeUrl('/contact/')} class:list={['header__link', { active: isActive('/contact/') }]}>Contact</a></li>
			</ul>
			<div class="header__actions">
				<a
					href={`tel:${SITE.phone}`}
					class="header__phone-btn"
					aria-label={`Call ${SITE.phoneDisplay}`}
				>
					<svg class="header__phone-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.56 1 1 0 01-.24 1.01l-2.2 2.22z"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</a>
				<a
					href={SITE.whatsappUrl}
					class="header__whatsapp-btn"
					target="_blank"
					rel="noopener noreferrer"
				>
					Ask on WhatsApp
				</a>
			</div>
			<a href={`tel:${SITE.phone}`} class="btn btn--primary header__cta">
				Call Now
			</a>
		</nav>
	</div>
</header>

<div class="sticky-cta" role="region" aria-label="Quick call to action">
	<a href={`tel:${SITE.phone}`} class="btn btn--primary sticky-cta__btn">Call {SITE.phoneDisplay}</a>
</div>

<script>
	const toggle = document.getElementById('menu-toggle');
	const nav = document.getElementById('nav-menu');
	if (toggle && nav) {
		toggle.addEventListener('click', () => {
			const open = nav.classList.toggle('header__nav--open');
			toggle.setAttribute('aria-expanded', String(open));
			toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
		});
		nav.querySelectorAll('a').forEach((a) => {
			a.addEventListener('click', () => {
				nav.classList.remove('header__nav--open');
				toggle.setAttribute('aria-expanded', 'false');
				toggle.setAttribute('aria-label', 'Open menu');
			});
		});
	}
</script>

<style>
	.header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: 16px 0;
		padding-top: calc(16px + var(--safe-top));
	}
	.header__bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		background: var(--color-nav-glass);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		padding: 10px 12px 10px 24px;
		max-width: min(var(--container), calc(100% - 32px));
		box-shadow: var(--color-shadow);
	}
	.header--transparent .header__bar {
		background: rgba(255, 255, 255, 0.92);
	}
	.header__logo {
		font-weight: 700;
		font-size: 1rem;
		color: var(--color-primary);
		white-space: nowrap;
		cursor: pointer;
	}
	.header__logo:hover {
		color: var(--color-cta);
		text-decoration: none;
	}
	.header__menu-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		background: var(--color-bg-elevated);
		border: 1px solid var(--color-border);
		border-radius: 50%;
		color: var(--color-text);
		cursor: pointer;
		flex-shrink: 0;
		transition: background 0.2s ease, border-color 0.2s ease;
	}
	.header__menu-btn:hover {
		background: var(--color-surface);
		border-color: var(--color-border-strong);
	}
	.header__menu-icon {
		display: block;
		width: 18px;
		height: 2px;
		background: currentColor;
		box-shadow: 0 6px 0 currentColor, 0 -6px 0 currentColor;
	}
	.header__nav {
		position: fixed;
		inset: 0;
		background: var(--color-surface);
		padding: calc(80px + var(--safe-top)) 24px 24px;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 24px;
		visibility: hidden;
		opacity: 0;
		transition: visibility 0.25s ease, opacity 0.25s ease;
		z-index: 99;
	}
	.header__nav--open {
		visibility: visible;
		opacity: 1;
	}
	.header__nav-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.header__link {
		display: block;
		font-size: 1.5rem;
		font-weight: 600;
		padding: 16px 0;
		color: var(--color-text-muted);
		border-bottom: 1px solid var(--color-border);
		cursor: pointer;
		transition: color 0.2s ease;
	}
	.header__link:hover,
	.header__link.active {
		color: var(--color-cta);
		text-decoration: none;
	}
	.header__actions {
		display: none;
	}
	.header__cta {
		width: 100%;
		margin-top: auto;
	}
	.sticky-cta {
		display: block;
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 12px 16px;
		padding-bottom: calc(12px + var(--safe-bottom));
		background: rgba(255, 255, 255, 0.96);
		backdrop-filter: blur(12px);
		border-top: 1px solid var(--color-border);
		box-shadow: 0 -4px 20px rgba(15, 23, 42, 0.06);
		z-index: 98;
	}
	.sticky-cta__btn {
		width: 100%;
	}
	@media (min-width: 768px) {
		.header__menu-btn {
			display: none;
		}
		.header__nav {
			position: static;
			visibility: visible;
			opacity: 1;
			background: none;
			backdrop-filter: none;
			padding: 0;
			flex-direction: row;
			align-items: center;
			gap: 8px;
		}
		.header__nav-list {
			flex-direction: row;
			align-items: center;
			gap: 4px;
		}
		.header__link {
			font-size: 0.875rem;
			font-weight: 500;
			padding: 8px 16px;
			border: none;
			border-radius: var(--radius-pill);
			color: var(--color-text-muted);
		}
		.header__link:hover,
		.header__link.active {
			color: var(--color-primary);
			background: var(--color-bg-elevated);
		}
		.header__actions {
			display: flex;
			align-items: center;
			gap: 8px;
			flex-shrink: 0;
		}
		.header__phone-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 40px;
			height: 40px;
			background: var(--color-surface);
			border: 1px solid var(--color-border);
			border-radius: 12px;
			color: var(--color-primary);
			flex-shrink: 0;
			cursor: pointer;
			transition: background 0.2s ease, border-color 0.2s ease;
		}
		.header__phone-btn:hover {
			background: var(--color-bg-elevated);
			border-color: var(--color-border-strong);
			text-decoration: none;
			color: var(--color-primary);
		}
		.header__phone-icon {
			display: block;
		}
		.header__whatsapp-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			height: 40px;
			padding: 0 18px;
			background: var(--color-cta);
			color: var(--color-cta-text);
			font-size: 0.875rem;
			font-weight: 600;
			border-radius: var(--radius-pill);
			white-space: nowrap;
			cursor: pointer;
			transition: background 0.2s ease;
		}
		.header__whatsapp-btn:hover {
			background: var(--color-cta-hover);
			color: var(--color-cta-text);
			text-decoration: none;
		}
		.header__cta {
			display: none;
		}
		.sticky-cta {
			display: none;
		}
	}
</style>
