---
interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
	<ol>
		{items.map((item, i) => (
			<li>
				{item.href ? (
					<a href={item.href}>{item.label}</a>
				) : (
					<span aria-current="page">{item.label}</span>
				)}
			</li>
		))}
	</ol>
</nav>
