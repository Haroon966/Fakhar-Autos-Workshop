---
import { SITE, GOOGLE_REVIEWS_SUMMARY } from '../data/site';
---

<aside class="quick-facts" id="quick-facts" aria-label="Business quick facts">
	<p class="quick-facts__title">{SITE.name} | Auto repair in F-11 Islamabad</p>
	<ul class="quick-facts__list">
		<li><strong>Address:</strong> {SITE.addressSingleLine}, {SITE.address.country}</li>
		<li><strong>Phone:</strong> <a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a></li>
		<li><strong>Hours:</strong> {SITE.hours}</li>
		<li><strong>Rating:</strong> {GOOGLE_REVIEWS_SUMMARY.rating}/5 ({GOOGLE_REVIEWS_SUMMARY.count} Google reviews)</li>
	</ul>
	<p class="quick-facts__speakable" id="speakable-nap">
		{SITE.name} is open Monday through Saturday, 9 AM to 7 PM, at {SITE.address.street}, {SITE.address.city}.
		Call {SITE.phoneDisplay}.
	</p>
</aside>

<style>
	.quick-facts {
		background: var(--color-bg-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 1.25rem 1.5rem;
		margin: 0 0 2rem;
	}
	.quick-facts__title {
		margin: 0 0 0.75rem;
		font-weight: 700;
		font-size: 1rem;
		color: var(--color-text);
	}
	.quick-facts__list {
		margin: 0 0 0.75rem;
		padding: 0 0 0 1.25rem;
		font-size: 0.9375rem;
		color: var(--color-text-muted);
		line-height: 1.65;
	}
	.quick-facts__list a {
		color: var(--color-text);
		font-weight: 600;
	}
	.quick-facts__speakable {
		margin: 0;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		line-height: 1.6;
	}
</style>
