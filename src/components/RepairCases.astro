---
import { REPAIR_CASES } from '../data/site';
---

<section class="section repair-cases-section" aria-labelledby="repair-cases-heading">
	<div class="layout">
		<header class="repair-cases-section__header">
			<h2 id="repair-cases-heading" class="section__title section__title--center">Selected Repair Cases</h2>
			<p class="section__intro section__intro--center">
				Real results from our recent diagnostics, engine work, and performance upgrades.
			</p>
			<a href="#gallery" class="repair-cases-section__cta">View All Cases</a>
		</header>

		<div class="repair-cases-grid">
			{REPAIR_CASES.map((item) => (
				<a href={item.href} class="case-card">
					<div class="case-card__media">
						<img src={item.image} alt={item.imageAlt} loading="lazy" width="640" height="400" />
					</div>
					<div class="case-card__body">
						<h3 class="case-card__title">{item.title}</h3>
						<p class="case-card__desc">{item.desc}</p>
						<span class="case-card__link">View Case →</span>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.repair-cases-section {
		background: #ffffff;
	}

	.repair-cases-section__header {
		text-align: center;
		margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
	}

	.repair-cases-section__header .section__intro {
		margin-bottom: 1.75rem;
	}

	.repair-cases-section__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: var(--tap-target);
		padding: 12px 28px;
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--color-cta-text);
		background: var(--color-cta);
		border-radius: var(--radius-pill);
		text-decoration: none;
		box-shadow: 0 2px 8px rgba(220, 38, 38, 0.25);
		transition: background 0.2s ease, box-shadow 0.2s ease;
	}

	.repair-cases-section__cta:hover {
		background: var(--color-cta-hover);
		color: var(--color-cta-text);
		text-decoration: none;
		box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
	}

	.repair-cases-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 20px;
	}

	@media (min-width: 768px) {
		.repair-cases-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 24px;
		}
	}

	.case-card {
		display: flex;
		flex-direction: column;
		background: #ffffff;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		color: inherit;
		text-decoration: none;
		box-shadow: var(--color-shadow);
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
		height: 100%;
	}

	.case-card:hover {
		border-color: var(--color-border-strong);
		box-shadow: var(--color-shadow-lg);
		text-decoration: none;
		color: inherit;
	}

	.case-card__media {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--color-bg-elevated);
	}

	.case-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: opacity 0.25s ease;
	}

	.case-card:hover .case-card__media img {
		opacity: 0.92;
	}

	@media (prefers-reduced-motion: reduce) {
		.case-card__media img {
			transition: none;
		}
	}

	.case-card__body {
		padding: 22px 24px 26px;
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-align: left;
	}

	.case-card__title {
		font-size: 1.0625rem;
		font-weight: 700;
		margin: 0 0 8px;
		color: var(--color-text);
		line-height: 1.35;
	}

	.case-card__desc {
		margin: 0 0 18px;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		line-height: 1.55;
		flex: 1;
	}

	.case-card__link {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--color-text);
		transition: color 0.2s ease;
	}

	.case-card:hover .case-card__link {
		color: var(--color-primary);
	}
</style>
