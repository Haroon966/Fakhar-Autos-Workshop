---
import { routeUrl } from '../utils/paths';

interface Props {
	slug: string;
	name: string;
	shortDesc: string;
	image?: string;
}

const { slug, name, shortDesc, image } = Astro.props;
---

<a href={routeUrl(`/services/${slug}/`)} class="service-card">
	{image && (
		<div class="service-card__media">
			<img src={image} alt={`${name} at Fakhar Auto Workshop`} loading="lazy" width="400" height="240" />
		</div>
	)}
	<div class="service-card__body">
		<h3 class="service-card__title">{name}</h3>
		<p class="service-card__desc">{shortDesc}</p>
		<span class="service-card__link">View service →</span>
	</div>
</a>

<style>
	.service-card {
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		color: inherit;
		text-decoration: none;
		cursor: pointer;
		box-shadow: var(--color-shadow);
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
		height: 100%;
	}
	.service-card:hover {
		border-color: var(--color-border-strong);
		box-shadow: var(--color-shadow-lg);
		text-decoration: none;
		color: inherit;
	}
	.service-card__media {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--color-bg-elevated);
	}
	.service-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: opacity 0.3s ease;
	}
	.service-card:hover .service-card__media img {
		opacity: 0.92;
	}
	.service-card__body {
		padding: 20px 22px 24px;
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	.service-card__title {
		font-size: 1.0625rem;
		font-weight: 600;
		margin: 0 0 8px;
		color: var(--color-text);
	}
	.service-card__desc {
		margin: 0 0 16px;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		line-height: 1.55;
		flex: 1;
	}
	.service-card__link {
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--color-cta);
		transition: color 0.2s ease;
	}
	.service-card:hover .service-card__link {
		color: var(--color-cta-hover);
	}
	@media (prefers-reduced-motion: reduce) {
		.service-card__media img {
			transition: none;
		}
	}
</style>
