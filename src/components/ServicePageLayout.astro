---
import Layout from '../layouts/Layout.astro';
import PageHero from './PageHero.astro';
import TrustBar from './TrustBar.astro';
import ServiceSidebar from './ServiceSidebar.astro';
import FAQBlock from './FAQBlock.astro';
import { SITE, SERVICES, SERVICE_FAQS } from '../data/site';
import { getBreadcrumbSchema, getFAQSchema } from '../data/schema';
import { pageUrl, routeUrl } from '../utils/paths';

interface Props {
	title: string;
	description: string;
	serviceName: string;
	heading: string;
	lead: string;
	slug: string;
	serviceSchema?: object;
	children: any;
}

const { title, description, serviceName, heading, lead, slug, serviceSchema, children } = Astro.props;
const service = SERVICES.find((s) => s.slug === slug);
const serviceIndex = SERVICES.findIndex((s) => s.slug === slug);
const prevSlug = serviceIndex > 0 ? SERVICES[serviceIndex - 1].slug : null;
const nextSlug = serviceIndex >= 0 && serviceIndex < SERVICES.length - 1 ? SERVICES[serviceIndex + 1].slug : null;
const serviceFaqs = SERVICE_FAQS[slug] ?? [];
const breadcrumbSchema = getBreadcrumbSchema([
	{ name: 'Home', url: pageUrl() },
	{ name: 'Services', url: pageUrl('services/') },
	{ name: serviceName, url: pageUrl(`services/${slug}/`) },
]);
const faqSchema = serviceFaqs.length > 0 ? getFAQSchema(serviceFaqs) : null;
const schemas = [breadcrumbSchema, ...(serviceSchema ? [serviceSchema] : []), ...(faqSchema ? [faqSchema] : [])];
---

<Layout
	title={title}
	description={description}
	canonical={pageUrl(`services/${slug}/`)}
	image={service?.image}
	imageAlt={`${serviceName} at ${SITE.name}`}
	schema={schemas}
	pageLayout="page"
>
	<article class="page">
		<PageHero
			title={heading}
			lead={lead}
			eyebrow={serviceName}
			breadcrumbs={[
				{ label: 'Home', href: '/' },
				{ label: 'Services', href: '/services/' },
				{ label: serviceName },
			]}
			image={service?.image}
			imageAlt={service ? `${serviceName} at ${SITE.name}` : ''}
		>
			<Fragment slot="actions">
				<a href={`tel:${SITE.phone}`} class="btn btn--primary">Call Now</a>
				<a href={SITE.whatsappUrl} class="btn btn--secondary" target="_blank" rel="noopener noreferrer">Ask on WhatsApp</a>
			</Fragment>
		</PageHero>

		<div class="page__body layout">
			<div class="page__grid">
				<div class="page__main prose">
					<slot />
					{serviceFaqs.length > 0 && (
						<FAQBlock items={serviceFaqs} heading={`${serviceName} — FAQ`} accordion={false} />
					)}
				</div>
				<ServiceSidebar currentSlug={slug} />
			</div>
		</div>

		<TrustBar />

		<nav class="service-pager" aria-label="Other services">
			<div class="layout service-pager__inner">
				{prevSlug && (
					<a href={routeUrl(`/services/${prevSlug}/`)} class="btn btn--secondary">
						← {SERVICES.find((s) => s.slug === prevSlug)?.name}
					</a>
				)}
				<a href={routeUrl('/services/')} class="btn btn--ghost">All Services</a>
				{nextSlug && (
					<a href={routeUrl(`/services/${nextSlug}/`)} class="btn btn--secondary">
						{SERVICES.find((s) => s.slug === nextSlug)?.name} →
					</a>
				)}
			</div>
		</nav>
	</article>
</Layout>
