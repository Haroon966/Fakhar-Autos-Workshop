---
import { FAQ_ITEMS, SITE } from '../data/site';
import FAQBlock from './FAQBlock.astro';
import { routeUrl } from '../utils/paths';
---

<section class="section faq-section" id="faq">
	<div class="layout">
		<header class="faq-section__header">
			<h2 class="section__title section__title--center">Frequently Asked Questions</h2>
			<p class="section__intro section__intro--center">
				Common questions about our services, pricing, and booking in Islamabad.
			</p>
			<a
				href={SITE.whatsappUrl}
				class="btn btn--primary"
				target="_blank"
				rel="noopener noreferrer"
			>
				Ask on WhatsApp
			</a>
		</header>
		<FAQBlock items={FAQ_ITEMS.slice(0, 6)} heading="" accordion />
		<p class="faq-section__more">
			<a href={routeUrl('/faq/')} class="btn btn--ghost">View all FAQs</a>
		</p>
	</div>
</section>

<style>
	.faq-section {
		background: #ffffff;
	}
	.faq-section__header {
		text-align: center;
		margin-bottom: clamp(2rem, 4vw, 2.5rem);
	}
	.faq-section__header .section__intro {
		margin-bottom: 1.75rem;
	}
	.faq-section__more {
		text-align: center;
		margin: 2rem 0 0;
	}
</style>
