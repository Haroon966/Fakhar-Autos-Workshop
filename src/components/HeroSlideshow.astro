---
import { HERO_SLIDES } from '../data/site';
---

<div class="hero-slideshow" data-hero-slideshow>
	<div class="hero-slideshow__track" aria-hidden="true">
		{HERO_SLIDES.map((slide, i) => (
			<div
				class:list={['hero-slideshow__slide', { 'hero-slideshow__slide--active': i === 0 }]}
				data-slide={i}
			>
				<img
					src={slide.src}
					alt={slide.alt}
					width="1920"
					height="1080"
					loading={i === 0 ? 'eager' : 'lazy'}
					fetchpriority={i === 0 ? 'high' : 'auto'}
					decoding="async"
				/>
			</div>
		))}
	</div>
	<div class="hero-slideshow__overlay"></div>
	<div class="hero-slideshow__controls">
		<button type="button" class="hero-slideshow__nav" data-prev aria-label="Previous slide">
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<path d="m15 18-6-6 6-6" />
			</svg>
		</button>
		<div class="hero-slideshow__dots" role="tablist" aria-label="Hero slides">
			{HERO_SLIDES.map((slide, i) => (
				<button
					type="button"
					class="hero-slideshow__dot"
					data-dot={i}
					role="tab"
					aria-selected={i === 0 ? 'true' : 'false'}
					aria-label={`Show slide ${i + 1}: ${slide.alt}`}
				/>
			))}
		</div>
		<button type="button" class="hero-slideshow__nav" data-next aria-label="Next slide">
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<path d="m9 18 6-6-6-6" />
			</svg>
		</button>
	</div>
</div>

<script>
	function initHeroSlideshow(root: HTMLElement) {
		if (root.dataset.ready === 'true') return;

		const slides = root.querySelectorAll<HTMLElement>('[data-slide]');
		const controls = root.querySelector<HTMLElement>('.hero-slideshow__controls');
		const total = slides.length;
		if (total === 0 || !controls) return;

		root.dataset.ready = 'true';

		let current = 0;
		let timer: ReturnType<typeof setInterval> | null = null;
		const intervalMs = 5500;
		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const dots = controls.querySelectorAll<HTMLButtonElement>('[data-dot]');

		const setSlide = (index: number) => {
			current = (index + total) % total;
			slides.forEach((slide, i) => {
				slide.classList.toggle('hero-slideshow__slide--active', i === current);
			});
			dots.forEach((dot, i) => {
				dot.setAttribute('aria-selected', i === current ? 'true' : 'false');
			});
		};

		const next = () => setSlide(current + 1);
		const prev = () => setSlide(current - 1);

		const start = () => {
			if (reducedMotion || total < 2) return;
			stop();
			timer = setInterval(next, intervalMs);
		};

		const stop = () => {
			if (timer) {
				clearInterval(timer);
				timer = null;
			}
		};

		controls.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			const nav = target.closest<HTMLButtonElement>('[data-prev], [data-next], [data-dot]');
			if (!nav) return;

			e.preventDefault();

			if (nav.hasAttribute('data-prev')) {
				prev();
			} else if (nav.hasAttribute('data-next')) {
				next();
			} else if (nav.hasAttribute('data-dot')) {
				setSlide(Number(nav.getAttribute('data-dot')));
			}

			start();
		});

		controls.addEventListener('keydown', (e) => {
			if (e.key === 'ArrowRight') {
				e.preventDefault();
				next();
				start();
			} else if (e.key === 'ArrowLeft') {
				e.preventDefault();
				prev();
				start();
			}
		});

		controls.addEventListener('mouseenter', stop);
		controls.addEventListener('mouseleave', start);
		controls.addEventListener('focusin', stop);
		controls.addEventListener('focusout', (e) => {
			if (!controls.contains(e.relatedTarget as Node)) start();
		});

		document.addEventListener('visibilitychange', () => {
			if (document.hidden) stop();
			else start();
		});

		start();
	}

	function initAllHeroSlideshows() {
		document.querySelectorAll<HTMLElement>('[data-hero-slideshow]').forEach(initHeroSlideshow);
	}

	initAllHeroSlideshows();
	document.addEventListener('astro:page-load', initAllHeroSlideshows);
</script>

<style>
	.hero-slideshow {
		position: absolute;
		inset: 0;
		z-index: 0;
		overflow: hidden;
	}
	.hero-slideshow__track {
		position: absolute;
		inset: 0;
	}
	.hero-slideshow__slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 1s ease;
	}
	.hero-slideshow__slide--active {
		opacity: 1;
		z-index: 1;
	}
	.hero-slideshow__slide img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		transform: scaleX(-1);
	}
	.hero-slideshow__overlay {
		position: absolute;
		inset: 0;
		z-index: 2;
		background: linear-gradient(
			to top,
			#f8fafc 0%,
			rgba(248, 250, 252, 0.95) 28%,
			rgba(248, 250, 252, 0.75) 50%,
			rgba(248, 250, 252, 0.35) 75%,
			rgba(248, 250, 252, 0.15) 100%
		);
		pointer-events: none;
	}
	.hero-slideshow__controls {
		position: absolute;
		bottom: clamp(5rem, 14vh, 7rem);
		left: 50%;
		transform: translateX(-50%);
		z-index: 10;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 6px 8px;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(8px);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		pointer-events: auto;
	}
	.hero-slideshow__dots {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 0 4px;
	}
	.hero-slideshow__nav {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		padding: 0;
		border: none;
		border-radius: 50%;
		background: transparent;
		color: var(--color-text);
		cursor: pointer;
		transition: background 0.2s ease, color 0.2s ease;
		flex-shrink: 0;
	}
	.hero-slideshow__nav:hover {
		background: var(--color-bg-elevated);
		color: var(--color-cta);
	}
	.hero-slideshow__nav:focus-visible {
		outline: 2px solid var(--color-cta);
		outline-offset: 2px;
	}
	.hero-slideshow__dot {
		width: 10px;
		height: 10px;
		padding: 0;
		border: none;
		border-radius: 50%;
		background: var(--color-border-strong);
		cursor: pointer;
		transition: background 0.2s ease;
	}
	.hero-slideshow__dot:hover {
		background: var(--color-text-muted);
	}
	.hero-slideshow__dot[aria-selected='true'] {
		background: var(--color-cta);
	}
	.hero-slideshow__dot:focus-visible {
		outline: 2px solid var(--color-cta);
		outline-offset: 2px;
	}
	@media (prefers-reduced-motion: reduce) {
		.hero-slideshow__slide {
			transition: none;
		}
	}
</style>
