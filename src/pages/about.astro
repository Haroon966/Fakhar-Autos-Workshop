---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import TrustBar from '../components/TrustBar.astro';
import { SITE } from '../data/site';
import { getBreadcrumbSchema } from '../data/schema';

const title = `About Us | ${SITE.name}`;
const description =
	'Learn about Fakhar Auto Workshop in Islamabad. Experienced team, quality parts, and commitment to customer satisfaction.';
const breadcrumbSchema = getBreadcrumbSchema([
	{ name: 'Home', url: SITE.url + '/' },
	{ name: 'About', url: SITE.url + '/about/' },
]);
---

<Layout
	title={title}
	description={description}
	canonical={`${SITE.url}/about/`}
	image="/images/facebook/fb-02.jpg"
	imageAlt={`Team at ${SITE.name}`}
	schema={breadcrumbSchema}
	pageLayout="page"
>
	<article class="page">
		<PageHero
			title={`About ${SITE.shortName}`}
			lead="Exceptional auto repair with honest communication, quality parts, and a team that treats every vehicle with care."
			eyebrow="Trusted in Islamabad"
			breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]}
			image="/images/facebook/fb-02.jpg"
			imageAlt={`Team at ${SITE.name}`}
		>
			<Fragment slot="actions">
				<a href={`tel:${SITE.phone}`} class="btn btn--primary">Call {SITE.phoneDisplay}</a>
				<a href="/contact/" class="btn btn--secondary">Contact Us</a>
			</Fragment>
		</PageHero>

		<div class="page__body layout">
			<div class="stats-row">
				<div class="stat-card">
					<p class="stat-card__value">{SITE.repairsCount}</p>
					<p class="stat-card__label">Successful repairs</p>
				</div>
				<div class="stat-card">
					<p class="stat-card__value">6+</p>
					<p class="stat-card__label">Service categories</p>
				</div>
				<div class="stat-card">
					<p class="stat-card__value">F-11</p>
					<p class="stat-card__label">Islamabad location</p>
				</div>
			</div>

			<div class="prose">
				<p>
					Our experienced team uses modern equipment and genuine or high-quality parts so your vehicle gets the
					best care possible. We have built trust across Islamabad through reliable work, clear updates, and fair
					pricing.
				</p>

				<h2>Our Values</h2>
				<div class="values-grid">
					<article class="value-card">
						<p class="value-card__label">Value 01</p>
						<h3 class="value-card__title">Quality</h3>
						<p class="value-card__desc">Genuine or high-quality parts and best practices on every job.</p>
					</article>
					<article class="value-card">
						<p class="value-card__label">Value 02</p>
						<h3 class="value-card__title">Honesty</h3>
						<p class="value-card__desc">We explain what your vehicle needs — no unnecessary work.</p>
					</article>
					<article class="value-card">
						<p class="value-card__label">Value 03</p>
						<h3 class="value-card__title">Speed</h3>
						<p class="value-card__desc">Efficient service so you are back on the road quickly.</p>
					</article>
					<article class="value-card">
						<p class="value-card__label">Value 04</p>
						<h3 class="value-card__title">Care</h3>
						<p class="value-card__desc">We stand behind our work with warranty on labor and parts.</p>
					</article>
				</div>

			</div>
		</div>

		<TrustBar />

		<div class="page__body layout">
			<div class="prose">
				<h2>Visit Our <span class="heading-accent">Workshop</span></h2>
				<p>
					We are at {SITE.addressSingleLine}, open {SITE.hours.toLowerCase()}. Call
					<a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a> or <a href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">message us on WhatsApp</a> to schedule a visit.
				</p>
			</div>
		</div>

	</article>
</Layout>
