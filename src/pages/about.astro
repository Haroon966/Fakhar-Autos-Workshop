---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import TrustBar from '../components/TrustBar.astro';
import QuickFacts from '../components/QuickFacts.astro';
import { SITE, ABOUT_CONTENT, SERVICE_AREAS } from '../data/site';
import { getAutoRepairSchema, getAboutPageSchema, getBreadcrumbSchema } from '../data/schema';
import { assetUrl, pageUrl, routeUrl } from '../utils/paths';

const title = `About Fakhar Auto Workshop — Trusted Auto Repair in F-11 Islamabad`;
const description =
	'Learn about Fakhar Auto Workshop in F-11 Islamabad. Experienced team, quality parts, modern equipment, and commitment to customer satisfaction.';
const breadcrumbSchema = getBreadcrumbSchema([
	{ name: 'Home', url: pageUrl() },
	{ name: 'About', url: pageUrl('about/') },
]);
---

<Layout
	title={title}
	description={description}
	canonical={pageUrl('about/')}
	image={assetUrl('/images/facebook/fb-02.jpg')}
	imageAlt={`Team at ${SITE.name}`}
	schema={[getAutoRepairSchema(), getAboutPageSchema(), breadcrumbSchema]}
	pageLayout="page"
>
	<article class="page">
		<PageHero
			title={`About ${SITE.shortName}`}
			lead="Exceptional auto repair with honest communication, quality parts, and a team that treats every vehicle with care."
			eyebrow="Trusted in Islamabad"
			breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]}
			image={assetUrl('/images/facebook/fb-02.jpg')}
			imageAlt={`Team at ${SITE.name}`}
		>
			<Fragment slot="actions">
				<a href={`tel:${SITE.phone}`} class="btn btn--primary">Call {SITE.phoneDisplay}</a>
				<a href={routeUrl('/contact/')} class="btn btn--secondary">Contact Us</a>
			</Fragment>
		</PageHero>

		<div class="page__body layout">
			<QuickFacts />

			<div class="stats-row">
				<div class="stat-card">
					<p class="stat-card__value">{SITE.repairsCount}</p>
					<p class="stat-card__label">Successful repairs</p>
				</div>
				<div class="stat-card">
					<p class="stat-card__value">6+</p>
					<p class="stat-card__label">Service categories</p>
				</div>
				<div class="stat-card">
					<p class="stat-card__value">F-11</p>
					<p class="stat-card__label">Islamabad location</p>
				</div>
			</div>

			<div class="prose">
				<h2>Who We Are</h2>
				<p>{ABOUT_CONTENT.story}</p>
				<p>{ABOUT_CONTENT.yearsInBusiness}. We serve drivers across Islamabad with transparent pricing and reliable results.</p>

				<h2>Our Team</h2>
				{ABOUT_CONTENT.team.map((member) => (
					<article class="team-card">
						<h3 class="team-card__name">{member.name}</h3>
						<p class="team-card__role">{member.role}</p>
						<p class="team-card__bio">{member.bio}</p>
					</article>
				))}

				<h2>Equipment &amp; Certifications</h2>
				<ul>
					{ABOUT_CONTENT.equipment.map((item) => (
						<li>{item}</li>
					))}
				</ul>

				<h2>Service Areas</h2>
				<p>We welcome customers from across Islamabad, including:</p>
				<ul>
					{SERVICE_AREAS.map((area) => (
						<li>{area}</li>
					))}
				</ul>

				<h2>Our Values</h2>
				<div class="values-grid">
					<article class="value-card">
						<p class="value-card__label">Value 01</p>
						<h3 class="value-card__title">Quality</h3>
						<p class="value-card__desc">Genuine or high-quality parts and best practices on every job.</p>
					</article>
					<article class="value-card">
						<p class="value-card__label">Value 02</p>
						<h3 class="value-card__title">Honesty</h3>
						<p class="value-card__desc">We explain what your vehicle needs — no unnecessary work.</p>
					</article>
					<article class="value-card">
						<p class="value-card__label">Value 03</p>
						<h3 class="value-card__title">Speed</h3>
						<p class="value-card__desc">Efficient service so you are back on the road quickly.</p>
					</article>
					<article class="value-card">
						<p class="value-card__label">Value 04</p>
						<h3 class="value-card__title">Care</h3>
						<p class="value-card__desc">We stand behind our work with warranty on labor and parts.</p>
					</article>
				</div>
			</div>
		</div>

		<TrustBar />

		<div class="page__body layout">
			<div class="prose">
				<h2>Visit Our <span class="heading-accent">Workshop</span></h2>
				<p>
					We are at {SITE.addressSingleLine}, open {SITE.hours.toLowerCase()}. Call
					<a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a> or <a href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">message us on WhatsApp</a> to schedule a visit.
				</p>
			</div>
		</div>
	</article>
</Layout>

<style>
	.team-card {
		margin-bottom: 1.5rem;
		padding: 1.25rem;
		background: var(--color-bg-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
	}
	.team-card__name {
		margin: 0 0 4px;
		font-size: 1.125rem;
	}
	.team-card__role {
		margin: 0 0 8px;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		font-weight: 600;
	}
	.team-card__bio {
		margin: 0;
		font-size: 0.9375rem;
		color: var(--color-text-muted);
		line-height: 1.6;
	}
</style>
