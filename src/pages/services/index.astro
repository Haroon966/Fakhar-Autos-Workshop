---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE, SERVICES } from '../../data/site';
import { getAutoRepairSchema, getBreadcrumbSchema, getItemListSchema } from '../../data/schema';
import { assetUrl, pageUrl } from '../../utils/paths';

const title = `Auto Repair Services in Islamabad | ${SITE.name}`;
const description =
	'Comprehensive auto repair services in Islamabad: electrical repairs, mechanical services, denting, painting, AC repair, oil change, brakes, and more.';
const breadcrumbSchema = getBreadcrumbSchema([
	{ name: 'Home', url: pageUrl() },
	{ name: 'Services', url: pageUrl('services/') },
]);
---

<Layout
	title={title}
	description={description}
	canonical={pageUrl('services/')}
	schema={[getAutoRepairSchema(), getItemListSchema(), breadcrumbSchema]}
	pageLayout="page"
>
	<article class="page">
		<PageHero
			title="Premium Maintenance for Every Vehicle"
			lead="Expert care for performance, safety, and long-term reliability — from diagnostics to denting, painting, and AC repair in F-11 Islamabad."
			eyebrow="Our services"
			breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Services' }]}
			image={assetUrl('/images/facebook/fb-01.jpg')}
			imageAlt="Auto repair services at Fakhar Auto Workshop"
		>
			<Fragment slot="actions">
				<a href={`tel:${SITE.phone}`} class="btn btn--primary">Call for a Quote</a>
				<a href={SITE.whatsappUrl} class="btn btn--secondary" target="_blank" rel="noopener noreferrer">Ask on WhatsApp</a>
			</Fragment>
		</PageHero>

		<div class="page__body layout">
			<div class="services-intro">
				<p class="services-intro__text">
					Choose a service below to learn what we offer at our F-11 Islamabad workshop. Every job starts with a clear inspection and upfront
					pricing — no hidden fees.
				</p>
			</div>
			<div class="services-grid">
				{SERVICES.map((s) => (
					<ServiceCard slug={s.slug} name={s.name} shortDesc={s.shortDesc} image={s.image} />
				))}
			</div>
		</div>

		<TrustBar />
	</article>
</Layout>
