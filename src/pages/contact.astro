---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import MapEmbed from '../components/MapEmbed.astro';
import { SITE } from '../data/site';
import { getAutoRepairSchema, getBreadcrumbSchema } from '../data/schema';

const title = `Contact | ${SITE.name}`;
const description =
	'Contact Fakhar Auto Workshop in Islamabad by phone or WhatsApp. Visit us for quotes, booking, and workshop hours.';
const breadcrumbSchema = getBreadcrumbSchema([
	{ name: 'Home', url: SITE.url + '/' },
	{ name: 'Contact', url: SITE.url + '/contact/' },
]);
---

<Layout title={title} description={description} canonical={`${SITE.url}/contact/`} schema={[getAutoRepairSchema(), breadcrumbSchema]} pageLayout="page">
	<article class="page">
		<PageHero
			title="Get In Touch"
			lead="Questions, quotes, or booking a service — message us on WhatsApp or call our workshop directly."
			eyebrow="We respond quickly"
			breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
		>
			<Fragment slot="actions">
				<a href={SITE.whatsappUrl} class="btn btn--primary" target="_blank" rel="noopener noreferrer">Ask on WhatsApp</a>
				<a href={`tel:${SITE.phone}`} class="btn btn--secondary">Call {SITE.phoneDisplay}</a>
			</Fragment>
		</PageHero>

		<div class="page__body layout">
			<div class="contact-cards">
				<a href={SITE.whatsappUrl} class="contact-card" target="_blank" rel="noopener noreferrer">
					<span class="contact-card__icon" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" /></svg>
					</span>
					<div>
						<p class="contact-card__label">WhatsApp</p>
						<p class="contact-card__value">Ask on WhatsApp</p>
					</div>
				</a>
				<a href={`tel:${SITE.phone}`} class="contact-card">
					<span class="contact-card__icon" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
					</span>
					<div>
						<p class="contact-card__label">Phone</p>
						<p class="contact-card__value">{SITE.phoneDisplay}</p>
					</div>
				</a>
				<a href={SITE.mapsUrl} class="contact-card" target="_blank" rel="noopener noreferrer">
					<span class="contact-card__icon" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" /></svg>
					</span>
					<div>
						<p class="contact-card__label">Address</p>
						<p class="contact-card__value">{SITE.addressSingleLine}</p>
					</div>
				</a>
				<div class="contact-card">
					<span class="contact-card__icon" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
					</span>
					<div>
						<p class="contact-card__label">Hours</p>
						<p class="contact-card__value">{SITE.hours}</p>
					</div>
				</div>
			</div>

			<div class="card contact-follow-card">
				<h2>Follow Us</h2>
				<p class="sidebar-meta">See recent work and updates on our Facebook page.</p>
				<a href={SITE.facebookUrl} class="btn btn--secondary" target="_blank" rel="noopener noreferrer">
					View Facebook Page
				</a>
			</div>

			<div class="map-block">
				<h2 class="map-block__title">Find Us on the Map</h2>
				<MapEmbed height={400} />
			</div>
		</div>
	</article>
</Layout>
