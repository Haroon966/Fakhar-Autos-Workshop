---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';

const title = `Page Not Found | ${SITE.name}`;
const description = 'The page you requested could not be found. Return to Fakhar Auto Workshop for auto repair services in Islamabad.';
---

<Layout title={title} description={description} noindex pageLayout="page">
	<article class="page not-found">
		<div class="layout not-found__inner">
			<p class="not-found__code" aria-hidden="true">404</p>
			<h1 class="not-found__title">Page not found</h1>
			<p class="not-found__lead">The link may be broken or the page may have been moved.</p>
			<div class="not-found__actions">
				<a href="/" class="btn btn--primary">Back to home</a>
				<a href="/services/" class="btn btn--secondary">View services</a>
				<a href="/contact/" class="btn btn--secondary">Contact us</a>
			</div>
		</div>
	</article>
</Layout>

<style>
	.not-found {
		min-height: 50vh;
		display: flex;
		align-items: center;
		padding: var(--section-pad) 0;
	}
	.not-found__inner {
		text-align: center;
		max-width: 36rem;
		margin-inline: auto;
	}
	.not-found__code {
		font-size: clamp(4rem, 12vw, 6rem);
		font-weight: 800;
		line-height: 1;
		color: var(--color-border);
		margin: 0 0 0.5rem;
	}
	.not-found__title {
		font-size: clamp(1.5rem, 4vw, 2rem);
		margin: 0 0 0.75rem;
	}
	.not-found__lead {
		color: var(--color-muted);
		margin: 0 0 2rem;
	}
	.not-found__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}
</style>
